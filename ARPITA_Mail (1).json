    {
      "parameters": {
        "jsCode": "const items = $input.all();\nconst updates = [];\n\nfor (const item of items) {\n  // Only process items that have row_numbers\n  if (!Array.isArray(item.json.row_numbers)) continue;\n\n  for (const row of item.json.row_numbers) {\n    updates.push({\n      json: {\n        row_number: row,\n        \"Mail Status\": true,\n        \"Timestamp\": new Date().toISOString()\n      }\n    });\n  }\n}\n\nreturn updates;\n"
      },
