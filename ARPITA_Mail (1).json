    {
      "parameters": {
        "jsCode": "const items = $input.all();\n\n// Get Mail Signature value directly from original sheet data\nconst mailSignature = $('Read Google Sheet').first().json['Mail Signature'] || \"\";\n\nlet companyBlock = \"\";\n\nif (mailSignature === \"HEMRAJ INDUSTRIES PVT LTD\") {\n  companyBlock = `\n  <br><br>\n  <b>HEMRAJ INDUSTRIES PVT LTD</b><br>\n  Factory Address: P.O+Vill: Chandul,G.T. Road, Purba Bardhaman, 713141, West Bengal<br>\n  GSTIN: 19AAACH8249K1Z4 &nbsp;&nbsp; PAN: AAACH8249K\n  `;\n}\n\nelse if (mailSignature === \"HEMRAJ RICE MILL\") {\n  companyBlock = `\n  <br><br>\n  <b>HEMRAJ RICE MILL</b><br>\n  Factory Address: Katwa Burdwan Road, Katwa, Purba Bardhaman, 713130, West Bengal<br>\n  GSTIN: 19AADFH4153N1Z2 &nbsp;&nbsp; PAN: AADFH4153N\n  `;\n}\n\nelse if (mailSignature === \"RADHASHYAM INDUSTRIES PVT LTD\") {\n  companyBlock = `\n  <br><br>\n  <b>RADHASHYAM INDUSTRIES PVT LTD</b><br>\n  Factory Address: Bhasapul, P.O: Pursha, P.S: Galsi, Purba Bardhaman, 713406, West Bengal<br>\n  GSTIN: 19AAGCR5957G1ZW &nbsp;&nbsp; PAN: AAGCR5957G\n  `;\n}\n\n// Attach same signature to every outgoing item (email group)\nfor (const item of items) {\n  item.json.companySignature = companyBlock;\n}\n\nreturn items;\n"
      },
