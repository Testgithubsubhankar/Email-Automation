    {
      "parameters": {
        "jsCode": "const grouped = {};\nconst items = $input.all();\n\nfor (const item of items) {\n  const rawEmails = item.json[\"Party Mail Address\"];\n  if (!rawEmails) continue;\n\n  const emails = rawEmails\n    .split(/[,;]+/)\n    .map(e => e.trim().toLowerCase())\n    .filter(Boolean);\n\n  for (const email of emails) {\n    if (!grouped[email]) {\n      grouped[email] = {\n        rows: [],\n        row_numbers: []\n      };\n    }\n\n    grouped[email].rows.push(item.json);\n    grouped[email].row_numbers.push(item.json.row_number);\n  }\n}\n\nreturn Object.keys(grouped).map(email => ({\n  json: {\n    email,\n    rows: grouped[email].rows,\n    row_numbers: grouped[email].row_numbers\n  }\n}));\n"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -128,
        384
      ],
      "id": "0d0325d8-673f-4721-bb10-d63d8dc01c68",
      "name": "Group by Party Mail Address"
    },
    {
      "parameters": {
        "jsCode": "const items = $input.all();\nconst output = [];\n\nfor (const item of items) {\n  const rows = item.json.rows;\n\n  let table = `\n<table border=\"1\" cellpadding=\"6\" cellspacing=\"0\" style=\"border-collapse:collapse;width:100%\">\n<tr>\n  <th>Item No</th>\n  <th>Item Description</th>\n  <th>UOM</th>\n  <th>Total Qty</th>\n</tr>`;\n\n  for (const r of rows) {\n    table += `\n<tr>\n  <td>${r[\"Item No\"]}</td>\n  <td>${r[\"Item Description\"]}</td>\n  <td>${r[\"UOM\"]}</td>\n  <td>${r[\"Total QTY\"]}</td>\n</tr>`;\n  }\n\n  table += `</table>`;\n\n  // ✅ take from FIRST row of this email group\n  const executivePhone = rows[0][\"Executive Phone Number\"] || \"\";\n  const shortenLink = rows[0][\"Shorten Link\"] || \"\";\n\n  output.push({\n    json: {\n      email: item.json.email,\n      table,\n      rows: item.json.rows,\n      row_numbers: item.json.row_numbers,\n      executivePhone,\n      shortenLink\n    }\n  });\n}\n\nreturn output;\n"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        0,
        0
      ],
      "id": "e6900662-10d0-4b17-96eb-a2be63e89c18",
      "name": "Build Multiple Item Table"
    },
    {
      "parameters": {
        "promptType": "define",
        "text": "=You are a procurement executive.\n\nYou MUST return a valid JSON object and NOTHING ELSE.\nDo NOT add explanations, comments, or text outside JSON.\nDo NOT use markdown.\nDo NOT add line breaks before or after JSON.\n\nYour task:\nWrite a professional RFQ email for multiple items.\n\nEmail rules:\n- Start email body with: Dear Sir, Write it in separate line\n- Mention the RFQ is for MULTIPLE items\n- Ask for unit price, total price, lead time, applicable taxes. Quotation validity is 3 days\n- Refer to the item details table provided below\n\n\nJSON FORMAT (STRICT — NO DEVIATION):\n\n{\n  \"email_subject\": \"Request for Quotation – Multiple Items\",\n  \"email_body\": \"Dear Sir,\\n\\nWe request you to kindly provide your quotation for multiple items as per the item details table provided below.\\n\\nPlease mention the unit price, total price, lead time, applicable taxes, and please confirm since our quotation validity is 3 days.\\n\\nWe look forward to your prompt response.\"\n}\n\n\n}\n\n",
