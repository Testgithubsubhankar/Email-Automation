        "jsCode": "let parsed;\n\ntry {\n  parsed = JSON.parse($input.first().json.output);\n} catch (e) {\n  throw new Error(\"AI output is not valid JSON\");\n}\n\nconst vendorName = parsed.vendorName || \"\";\nconst items = parsed.items || [];\n\nif (!items.length) {\n  throw new Error(\"No items found in quotation\");\n}\n\n// Convert each item into a row for Google Sheets\nconst rows = items.map(item => ({\n  json: {\n    \"Vendor Name\": vendorName,\n    \"Item Name\": item.itemName || item.itemNames || \"\",\n    \"Quantity\": item.Quantity || 0,\n    \"Unit Rate\": item[\"Unit Rate\"] || item.UnitRate || 0,\n    \"DiscountPercent\": item.DiscountPercent || 0,\n    \"Total Amount\": item[\"Total Amount\"] || item.TotalAmount || 0,\n  }\n}));\n\nreturn rows;\n"
