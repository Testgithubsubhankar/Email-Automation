    {
      "parameters": {
        "jsCode": "const rows = $input.all();\n\nlet combined = \"\";\n\nfor (const r of rows) {\n  combined += JSON.stringify(r.json) + \"\\n\";\n}\n\nreturn [\n  {\n    json: {\n      documentText: combined\n    }\n  }\n];\n\n\n"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -288,
        -192
      ],
      "id": "a3b21c5f-b3d7-4f66-8a89-82403473ac5a",
      "name": "Code in JavaScript5"
    },
    {
      "parameters": {
        "jsCode": "return items.flatMap(item => {\n  const binaries = item.binary || {};\n\n  return Object.keys(binaries).map(key => {\n    return {\n      json: {\n        fileName: binaries[key].fileName,\n        mimeType: binaries[key].mimeType,\n        fileType: binaries[key].fileType,\n        fileExtension: binaries[key].fileExtension,\n        fileSize: binaries[key].fileSize,\n        key,\n        from: item.json.from,\n        to: item.json.to,\n        subject: item.json.subject || \"\",\n        date: item.json.date\n      },\n      \n      binary: {\n        data: binaries[key]\n      }\n    };\n  });\n});\n"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -1088,
        -32
      ],
      "id": "067032f2-569d-4c4f-ab23-92b4891e7d9f",
      "name": "Code in JavaScript4"
    },
    {
      "parameters": {
        "jsCode": "return items.map(item => {\n  const mail = item.json;\n  const binary = item.binary || {};\n\n  const attachments = [];\n  const filteredBinary = {};\n\n  Object.keys(binary).forEach(key => {\n    const mimeType = binary[key].mimeType || '';\n\n    // ❌ Skip image attachments\n    if (mimeType.startsWith('image/')) return;\n\n    // ✅ Keep non-image attachments\n    attachments.push({\n      binaryKey: key,\n      fileName: binary[key].fileName,\n      mimeType: mimeType,\n      fileSize: binary[key].fileSize,\n    });\n\n    filteredBinary[key] = binary[key];\n  });\n\n  return {\n    json: {\n      email_from_name: mail.from?.value?.[0]?.name || null,\n      email_from_address: mail.from?.value?.[0]?.address || null,\n      subject: mail.headers?.subject || '',\n      body_text: mail.text || mail.html || '',\n      attachments, // non-image metadata only\n      received_date: mail.date || null,\n    },\n    binary: filteredBinary // ✅ images fully removed\n  };\n});\n"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -1824,
        112
      ],
      "id": "16ca1c56-0f3d-45d7-b43a-5acb77f547a0",
      "name": "Code in Javascript1"
    },
    {
      "parameters": {
        "jsCode": "return items.map((item) => {\n  let html =\n    item.json.html ||\n    item.json.body?.html ||\n    item.json.payload?.body?.html ||\n    '';\n\n  let text =\n    item.json.text ||\n    item.json.body?.text ||\n    item.json.payload?.body?.text ||\n    '';\n\n  if (html) {\n    text = html\n      .replace(/<script[\\s\\S]*?>[\\s\\S]*?<\\/script>/gi, '')\n      .replace(/<style[\\s\\S]*?>[\\s\\S]*?<\\/style>/gi, '')\n      .replace(/<br\\s*\\/?>/gi, '\\n')\n      .replace(/<\\/p>/gi, '\\n')\n      .replace(/<[^>]+>/g, '')\n      .replace(/&nbsp;/gi, ' ')\n      .replace(/&amp;/gi, '&')\n      .replace(/&lt;/gi, '<')\n      .replace(/&gt;/gi, '>')\n      .replace(/&quot;/gi, '\"')\n      .replace(/&#39;/gi, \"'\")\n      .replace(/\\r\\n/g, '\\n')\n      .replace(/\\n{2,}/g, '\\n')\n      .trim();\n  }\n\n  return {\n    json: {\n      ...item.json,\n      email_text: text,\n    },\n    binary: item.binary, \n  };\n});\n"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -1376,
        416
      ],
      "id": "fe99be78-4077-4d1e-b60b-19a012d1f57f",
      "name": "Code in Javascript2"
    },
    {
      "parameters": {
        "jsCode": "let parsed;\n\ntry {\n  parsed = JSON.parse($json.output);\n} catch {\n  throw new Error(\"AI output is not valid JSON\");\n}\n\nconst items = parsed.items || [];\nif (!items.length) {\n  throw new Error(\"No items found in quotation\");\n}\n\n// Subtotal\nconst subtotal = items.reduce((s, i) => s + Number(i.lineAmount), 0);\n\n// Apply GST if mentioned in document (we assume yes here)\n// const gstRate = 0.18;\n// const gstAmount = +(subtotal * gstRate).toFixed(2);\n// const finalTotal = +(subtotal + gstAmount).toFixed(2);\n\n\n// parsed.subtotal = +subtotal.toFixed(2);\n// parsed.gstAmount = gstAmount;\n// parsed.quotationAmount = finalTotal;\n\n// Return normalized object\nreturn {\n  vendorName: parsed.vendorName,\n  // subtotal: parsed.subtotal,\n  // gstAmount: parsed.gstAmount,\n  // quotationAmount: parsed.quotationAmount,\n  items\n};\n"
      },
